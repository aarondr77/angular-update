{
  "name": "client-servicing-console",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:api": "json-server --watch mock-api/db.json --port 3000 --routes mock-api/routes.json",
    "start:app": "ng serve --proxy-config proxy.conf.json",
    "start": "concurrently \"npm run start:api\" \"npm run start:app\"",
    "build": "ng build",
    "build:prod": "npx ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "ng lint",
    "e2e": "cypress run",
    "e2e:open": "cypress open",
    "e2e:visual": "cypress run --spec cypress/e2e/visual-regression.cy.ts",
    "ci": "npm run lint && npm run test && npm run build:prod"
  },
  "private": true,
  "engines": {
    "node": ">=18.13.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@angular/animations": "19.2.25",
    "@angular/cdk": "^18.2.14",
    "@angular/common": "19.2.25",
    "@angular/compiler": "19.2.25",
    "@angular/core": "19.2.25",
    "@angular/flex-layout": "^15.0.0-beta.42",
    "@angular/forms": "19.2.25",
    "@angular/material": "^18.2.14",
    "@angular/platform-browser": "19.2.25",
    "@angular/platform-browser-dynamic": "19.2.25",
    "@angular/router": "19.2.25",
    "@bofa/legacy-sparkline-widget": "file:packages/legacy-sparkline-widget",
    "@ngrx/effects": "^18.1.1",
    "@ngrx/entity": "^18.1.1",
    "@ngrx/store": "^18.1.1",
    "@ngrx/store-devtools": "^18.1.1",
    "rxjs": "~7.5.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.27",
    "@angular-eslint/builder": "^18.4.3",
    "@angular-eslint/eslint-plugin": "^18.4.3",
    "@angular-eslint/eslint-plugin-template": "^18.4.3",
    "@angular-eslint/schematics": "^18.4.3",
    "@angular-eslint/template-parser": "^18.4.3",
    "@angular/cli": "19.2.27",
    "@angular/compiler-cli": "19.2.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^16.18.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axe-core": "^4.8.4",
    "concurrently": "^7.6.0",
    "cypress": "12.17.4",
    "cypress-image-snapshot": "4.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "29.7.0",
    "jest-axe": "8.0.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-preset-angular": "^14.4.2",
    "json-server": "0.17.4",
    "prettier": "^2.8.8",
    "typescript": "~5.8.3"
  }
}
